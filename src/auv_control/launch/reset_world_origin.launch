<!--
名称：reset_world_origin.launch
功能：启动红色圆形感知链路并执行一次性世界坐标系原点重置
作者：buyegaid
订阅：/obj/target_message、/world_origin_reset_result
发布：/world_origin_reset_candidate
记录：
2026.7.13
    新增独立原点重置启动文件；重置节点结束时停止本启动文件中的感知链路。
-->
<launch>
    <!-- 需先单独启动 begin.launch，使 /world_origin 和 map 到 camera 的 TF 可用。 -->
    <include file="$(find stereo_depth)/launch/test_red_circle_detection.launch" >
        <arg name="start_camera" value="false" />
        <arg name="start_splitter" value="false" />
        <arg name="start_web" default="true" />
    </include>

    <!-- 节点结束时 required 会停止本 launch 中的感知链路。 -->
    <node pkg="auv_control" type="world_origin_reset.py" name="world_origin_reset" output="screen" required="true">
        <param name="target_topic" value="/vision/red_circle/target_message" />
        <param name="target_class" value="red_circle" />
        <param name="source_frame" value="camera" />
        <param name="reference_frame" value="map" />
        <param name="min_confidence" value="0.2" />
        <param name="sample_count" value="10" />
        <param name="min_inliers" value="8" />
        <param name="max_spread" value="0.20" />
        <param name="min_inlier_radius" value="0.03" />
        <param name="tf_ready_timeout_sec" value="180.0" />
        <param name="observation_timeout_sec" value="180.0" />
        <param name="result_timeout_sec" value="5.0" />
    </node>
</launch>
