<launch>
    <!-- begin.launch — 启动下位机驱动和tf -->
    <!-- 用法: roslaunch auv_control begin.launch -->

    <!-- 启动节点参数 -->
    <arg name="start_camera" default="true" />
    <arg name="start_splitter" default="true" />
    <arg name="start_state_web" default="true" />
    <arg name="start_fisheye" default="true" />
    <arg name="start_motion_supervisor" default="false" />

    <!-- 包含任务参数 -->
    <!-- <include file="$(find auv_control)/launch/param.launch"/> -->
    <arg name="save_dir" default="$(env HOME)/.ros/auv_logs" />
    <arg name="motion_supervisor_config_file"  default="$(find auv_control)/config/motion_supervisor.yaml" />
    <arg name="tf_config_file" default="$(find auv_control)/config/auv_tf.yaml" />

    <!-- 下位机ip -->
    <arg name="vehicle_ip" default="192.168.1.115" />

    <!-- debug_driver_v2 向下位机发送完整控制帧的频率，单位 Hz。 -->
    <arg name="debug_send_rate_hz" default="20.0" />
    
    <!-- web 参数 -->    
    <arg name="state_web_host" default="0.0.0.0" />
    <arg name="state_web_port" default="8088" />

    <!-- 鱼眼相机驱动 -->
    <arg name="camera_host" default="192.168.1.122" />
    <arg name="camera_port" default="554" />
    <arg name="username" default="admin" />
    <arg name="password" default="admin" />
    <arg name="channel" default="1" />
    <arg name="subtype" default="0" />
    <arg name="image_topic" default="/fisheye_camera/image_raw" />

    <!-- ===== 硬件驱动层 ===== -->

    <!-- 传感器状态 (TCP 5064, STATUS 帧接收) -->
    <node pkg="auv_control" type="sensor_status_node.py" name="sensor_status_node" output="screen">
        <param name="sensor_ip" value="$(arg vehicle_ip)" />
        <param name="sensor_port" value="5064" />
        <param name="save_raw_data" type="bool" value="true" />
        <param name="raw_save_dir" type="string" value="$(arg save_dir)" />
        <param name="raw_flush_every" type="int" value="1" />
    </node>

    <!-- 传感器执行器 (TCP 5064, 补光灯/舵机/推杆控制) -->
    <node pkg="auv_control" type="sensor_actuator_node.py" name="sensor_actuator_node" output="screen">
        <param name="sensor_ip" value="$(arg vehicle_ip)" />
        <param name="sensor_port" value="5064" />
    </node>

    <!-- 调试驱动 V2 (TCP 5063, 支持定深/定深定向/定点三种模式) -->
    <node pkg="auv_control" type="debug_driver_v2.py" name="debug_driver_v2" output="screen">
        <param name="debug_ip" value="$(arg vehicle_ip)"/>
        <param name="debug_port" value="5063"/>
        <param name="save_raw_data" type="bool" value="true" />
        <param name="raw_save_dir" type="string" value="$(arg save_dir)" />
        <param name="raw_flush_every" type="int" value="1" />
        <param name="send_rate_hz" type="double" value="$(arg debug_send_rate_hz)" />
    </node>

    <!-- ===== 坐标变换层 ===== -->

    <!-- 地图原点初始化 -->
    <node pkg="auv_control" type="map_initer.py" name="map_initer" output="screen"/>

    <!-- 同步发布 map -> base_link 与 YAML 定义的全部静态 TF，并转换控制指令。 -->
    <node pkg="auv_control" type="auv_tf_handler.py" name="auv_tf_handler" output="screen">
        <!-- 配置路径通过 find 解析，适用于 Linux 下的任意工作空间。 -->
        <rosparam command="load" file="$(arg tf_config_file)" />
    </node>

    <!-- 运行状态 Web：声明在坐标系节点之后，自行等待 /world_origin 和 map -> base_link TF 就绪 -->
    <group if="$(arg start_state_web)">
        <include file="$(find state_web)/launch/state_web.launch">
            <arg name="host" value="$(arg state_web_host)" />
            <arg name="port" value="$(arg state_web_port)" />
        </include>
    </group>

    <!-- <node pkg="auv_control" type="state_control.py" name="state_control" output="screen"/> -->
    
    <!-- 启动 USB 相机 -->
    <node if="$(arg start_camera)" name="usb_cam" pkg="usb_cam" type="usb_cam_node" launch-prefix="bash -c 'rosrun usb_cam usb_cam_node _video_device:=/dev/video0 _pixel_format:=mjpeg _image_width:=1280 _image_height:=480 2>/dev/null; $0 $@'" />

    <!-- 图像左右分割节点 -->
    <node if="$(arg start_splitter)" pkg="stereo_splitter" type="split_stereo_image.py" name="split_stereo_image" output="screen" />

    <!-- 启动鱼眼相机 -->
    <include if="$(arg start_fisheye)"
             file="$(find fisheye_camera_driver)/launch/driver.launch">
        <arg name="host" value="$(arg camera_host)" />
        <arg name="port" value="$(arg camera_port)" />
        <arg name="username" value="$(arg username)" />
        <arg name="password" value="$(arg password)" />
        <arg name="channel" value="$(arg channel)" />
        <arg name="subtype" value="$(arg subtype)" />
        <arg name="image_topic" value="$(arg image_topic)" />
    </include>
    
    <!-- 启动控制状态机 -->
    <include if="$(arg start_motion_supervisor)"
             file="$(find auv_control)/launch/motion_supervisor_prototype.launch">
        <arg name="start_goal_test" value="false" />
        <arg name="config_file" value="$(arg motion_supervisor_config_file)" />
        <arg name="tf_config_file" value="$(arg tf_config_file)" />
    </include>
</launch>
