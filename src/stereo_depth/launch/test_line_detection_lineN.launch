<launch>
    <!-- 线分割 -> 骨架主路径 -> N个等弧长像素点 -> N个三维点 -->

    <arg name="start_camera" default="false" />
    <arg name="start_splitter" default="false" />
    <arg name="start_web" default="true" />

    <arg name="model_path"
         default="/home/xhy/catkin_ws/models/line0709.pt" />

    <!-- 10或20均可 -->
    <arg name="line_sample_count" default="10" />

    <arg name="exp_env" default="water" />
    <arg name="conf_thre" default="0.2" />
    <arg name="top_k" default="1" />
    <arg name="rate" default="5.0" />
    <arg name="visualization" default="0" />
    <arg name="web_port" default="8080" />

    <node if="$(arg start_camera)"
          pkg="usb_cam"
          type="usb_cam_node"
          name="usb_cam"
          output="log">
        <param name="video_device" value="/dev/video0" />
        <param name="pixel_format" value="mjpeg" />
        <param name="image_width" value="1280" />
        <param name="image_height" value="480" />
        <param name="framerate" value="30" />
    </node>

    <node if="$(arg start_splitter)"
          pkg="stereo_splitter"
          type="split_stereo_image.py"
          name="split_stereo_image"
          output="screen" />

    <node pkg="yolo_bridge"
          type="yolo_wrapper_lineN.sh"
          name="yolo_line_detector"
          output="screen"
          launch-prefix="bash">

        <env name="NODE_NAME" value="/yolo_line_detector" />

        <param name="task_mode" value="segment_line" />
        <param name="detect_mode" value="4" />
        <param name="model_path" value="$(arg model_path)" />
        <param name="top_k" value="$(arg top_k)" />
        <param name="visualization" value="$(arg visualization)" />
        <param name="conf_thre" value="$(arg conf_thre)" />
        <param name="detc_type" value="center" />

        <!-- 沿骨架主路径等弧长采样 -->
        <param name="output_type" value="uniform_path" />
        <param name="line_sample_count"
               value="$(arg line_sample_count)" />

        <param name="infer_rate" value="$(arg rate)" />
        <param name="input_topic" value="/left/image_raw" />
        <param name="annotated_topic"
               value="/vision/line/annotated_image" />
        <param name="web_topic" value="/vision/line/detections" />
        <param name="center_topic"
               value="/vision/line/target_center" />
        <param name="bbox_topic"
               value="/vision/line/target_bbox" />
        <param name="line_topic"
               value="/vision/line/line_points" />
    </node>

    <node pkg="stereo_depth"
          type="stereo_depth_node_lineN_v2.py"
          name="stereo_depth_line"
          output="screen">

        <param name="task_mode" value="line" />
        <param name="exp_env" value="$(arg exp_env)" />
        <param name="visualization" value="$(arg visualization)" />
        <param name="conf_thre" value="$(arg conf_thre)" />
        <param name="rate" value="$(arg rate)" />

        <param name="left_topic" value="/left/image_raw" />
        <param name="right_topic" value="/right/image_raw" />
        <param name="line_topic"
               value="/vision/line/line_points" />

        <param name="line_output_topic"
               value="/vision/line/line_message" />
        <param name="web_pose_topic"
               value="/vision/line/pose" />

        <param name="max_sync_dt" value="0.15" />
        <param name="frame_buffer_size" value="20" />

        <!-- 多点深度不建议使用min，median更稳健 -->
        <param name="depth_statistic" value="median" />
        <param name="window_size" value="15" />

        <!-- 20点中至少10点有效即可认为整条线有效 -->
        <param name="min_valid_line_points" value="5" />
        <param name="min_valid_line_ratio" value="0.5" />
        <param name="require_all_line_points" value="false" />
        <param name="require_line_depth_order" value="false" />
        <param name="reverse_line_points" value="false" />
    </node>

    <include if="$(arg start_web)"
             file="$(find vision_web)/launch/vision_web.launch">
        <arg name="port" value="$(arg web_port)" />
        <arg name="image_topic"
             value="/vision/line/annotated_image" />
        <arg name="detection_topic"
             value="/vision/line/detections" />
        <arg name="pose_topic"
             value="/vision/line/pose" />
        <arg name="stream_fps" value="$(arg rate)" />
        <arg name="jpeg_quality" value="75" />
        <arg name="web_width" value="960" />
        <arg name="detection_timeout" value="2.0" />
        <arg name="pose_timeout" value="2.0" />
    </include>
</launch>
