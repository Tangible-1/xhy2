<launch>
    <!--
        YOLO Pose箭头识别：
        左图 -> Pose模型 -> tip/tail_left/tail_right
             -> 直接计算二维方向 -> 连续话题 -> Web

        本launch不使用阈值分割、形态学、轮廓或PCA。
    -->

    <arg name="start_camera" default="false" />
    <arg name="start_splitter" default="false" />
    <arg name="start_web" default="true" />
    <arg name="start_depth" default="true" />

    <!-- 请将训练得到的best.pt复制并重命名到该位置 -->
    <arg name="model_path"
         default="/home/xhy/catkin_ws/models/arrow_pose0720.pt" />
    <arg name="conf_thre" default="0.10" />
    <arg name="keypoint_conf_thre" default="0.1" />
    <arg name="top_k" default="3" />
    <arg name="rate" default="5.0" />
    <arg name="imgsz" default="640" />
    <arg name="device" default="0" />
    <arg name="visualization" default="0" />
    <arg name="web_port" default="8080" />

    <!-- 1 Hz rosbag建议1.5~2.0；实时5 Hz可设0.8~1.0 -->
    <arg name="keypoint_timeout" default="1.5" />
    <arg name="max_sync_dt" default="1.2" />
    <arg name="min_direction_length_px" default="15.0" />

    <arg name="input_topic" default="/left/image_raw" />

    <!-- ================= 箭头三维定位参数 ================= -->
    <arg name="right_topic" default="/right/image_raw" />
    <arg name="arrow_center_topic"
         default="/vision/arrow/center" />

    <!-- 三关键点代表中心：keypoint_centroid 或 axis_midpoint -->
    <arg name="depth_center_mode"
         default="keypoint_centroid" />

    <!-- 在代表中心周围取 window_size x window_size 深度窗口 -->
    <arg name="window_size" default="25" />
    <arg name="depth_statistic" default="mean" />
    <arg name="min_valid_pixels" default="3" />
    <arg name="min_depth" default="0.5" />
    <arg name="max_depth" default="2.0" />

    <arg name="depth_max_sync_dt" default="0.15" />
    <arg name="frame_buffer_size" default="20" />
    <arg name="exp_env" default="water" />

    <!-- StereoSGBM参数 -->
    <arg name="min_disparity" default="0" />
    <arg name="num_disparities" default="96" />
    <arg name="block_size" default="7" />

    <!-- ================= 相机 ================= -->

    <node if="$(arg start_camera)"
          name="usb_cam"
          pkg="usb_cam"
          type="usb_cam_node"
          output="screen"
          launch-prefix="bash -c 'exec &quot;$0&quot; &quot;$@&quot; 2>/dev/null'">

        <param name="video_device" value="/dev/video0" />
        <param name="pixel_format" value="mjpeg" />
        <param name="image_width" value="1280" />
        <param name="image_height" value="480" />
        <param name="framerate" value="30" />
    </node>

    <node if="$(arg start_splitter)"
          pkg="stereo_splitter"
          type="split_stereo_image.py"
          name="split_stereo_image"
          output="screen" />

    <!-- ================= YOLO Pose ================= -->

    <node pkg="yolo_bridge"
          type="yolo_pose_arrow_wrapper.sh"
          name="yolo_arrow_pose_detector"
          output="screen"
          launch-prefix="bash">

        <env name="NODE_NAME"
             value="/yolo_arrow_pose_detector" />

        <param name="model_path"
               value="$(arg model_path)" />
        <param name="top_k"
               value="$(arg top_k)" />
        <param name="visualization"
               value="$(arg visualization)" />
        <param name="conf_thre"
               value="$(arg conf_thre)" />
        <param name="keypoint_conf_thre"
               value="$(arg keypoint_conf_thre)" />
        <param name="infer_rate"
               value="$(arg rate)" />
        <param name="imgsz"
               value="$(arg imgsz)" />
        <param name="device"
               value="$(arg device)" />

        <param name="input_topic"
               value="$(arg input_topic)" />
        <param name="annotated_topic"
               value="/vision/arrow/pose_annotated_image" />
        <param name="web_topic"
               value="/vision/arrow/detections" />
        <param name="keypoint_topic"
               value="/vision/arrow/keypoints" />
        <param name="bbox_topic"
               value="/vision/arrow/target_bbox" />
    </node>

    <!-- ================= 三关键点方向计算 ================= -->

    <node pkg="stereo_depth"
          type="arrow_pose_direction_node.py"
          name="arrow_pose_direction_node"
          output="screen">

        <param name="image_topic"
               value="$(arg input_topic)" />
        <param name="keypoint_topic"
               value="/vision/arrow/keypoints" />
        <param name="center_topic"
               value="$(arg arrow_center_topic)" />
        <param name="center_mode"
               value="$(arg depth_center_mode)" />
        <param name="depth_window_size"
               value="$(arg window_size)" />
        <param name="target_class_name"
               value="arrow" />

        <param name="annotated_topic"
               value="/vision/arrow/direction_annotated_image" />
        <param name="direction_topic"
               value="/vision/arrow/direction" />
        <param name="angle_topic"
               value="/vision/arrow/angle_deg" />
        <param name="discrete_topic"
               value="/vision/arrow/discrete_direction" />
        <param name="vector_topic"
               value="/vision/arrow/direction_vector" />

        <param name="publish_rate"
               value="$(arg rate)" />
        <param name="keypoint_timeout"
               value="$(arg keypoint_timeout)" />
        <param name="max_sync_dt"
               value="$(arg max_sync_dt)" />
        <param name="min_keypoint_confidence"
               value="$(arg keypoint_conf_thre)" />
        <param name="min_direction_length_px"
               value="$(arg min_direction_length_px)" />
        <param name="visualization"
               value="$(arg visualization)" />
    </node>

    <!-- ================= 箭头三维位置计算 ================= -->
    <!--
        arrow_pose_direction_node.py 发布:
            /vision/arrow/center  geometry_msgs/PointStamped

        stereo_depth_node.py 使用该像素周围 window_size 区域的
        有效深度均值，发布:
            /vision/arrow/target_message
            /vision/arrow/pose
    -->
    <node if="$(arg start_depth)"
          pkg="stereo_depth"
          type="stereo_depth_node.py"
          name="stereo_depth_arrow_pose"
          output="screen">

        <param name="task_mode" value="center" />
        <param name="exp_env" value="$(arg exp_env)" />
        <param name="visualization"
               value="$(arg visualization)" />
        <param name="conf_thre"
               value="$(arg conf_thre)" />
        <param name="rate"
               value="$(arg rate)" />

        <param name="left_topic"
               value="$(arg input_topic)" />
        <param name="right_topic"
               value="$(arg right_topic)" />
        <param name="center_topic"
               value="$(arg arrow_center_topic)" />

        <param name="window_size"
               value="$(arg window_size)" />
        <param name="depth_statistic"
               value="$(arg depth_statistic)" />
        <param name="min_valid_pixels"
               value="$(arg min_valid_pixels)" />
        <param name="min_depth"
               value="$(arg min_depth)" />
        <param name="max_depth"
               value="$(arg max_depth)" />

        <param name="max_sync_dt"
               value="$(arg depth_max_sync_dt)" />
        <param name="frame_buffer_size"
               value="$(arg frame_buffer_size)" />

        <param name="min_disparity"
               value="$(arg min_disparity)" />
        <param name="num_disparities"
               value="$(arg num_disparities)" />
        <param name="block_size"
               value="$(arg block_size)" />

        <param name="target_output_topic"
               value="/vision/arrow/target_message" />
        <param name="web_pose_topic"
               value="/vision/arrow/pose" />
    </node>
    
    <!-- ================= Web ================= -->

    <include if="$(arg start_web)"
             file="$(find vision_web)/launch/vision_web_v2.launch">

        <arg name="port"
             value="$(arg web_port)" />
        <arg name="image_topic"
             value="/vision/arrow/direction_annotated_image" />
        <arg name="detection_topic"
             value="/vision/arrow/detections" />
        <arg name="pose_topic"
             value="/vision/arrow/pose" />
        <arg name="arrow_topic"
             value="/vision/arrow/direction" />

        <arg name="stream_fps"
             value="$(arg rate)" />
        <arg name="jpeg_quality"
             value="75" />
        <arg name="web_width"
             value="960" />
        <arg name="detection_timeout"
             value="2.0" />
        <arg name="pose_timeout"
             value="2.0" />
        <arg name="arrow_timeout"
             value="2.0" />
    </include>
</launch>
